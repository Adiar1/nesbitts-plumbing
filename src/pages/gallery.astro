  { src: '/images/gallery/gallery-23.jpg', caption: '', alt: 'Plumbing services in Asheville, NC' },
  { src: '/images/gallery/gallery-24.jpg', caption: '', alt: 'Plumbing services in Asheville, NC' },
  { src: '/images/gallery/gallery-25.jpg', caption: '', alt: 'Plumbing services in Asheville, NC' },
