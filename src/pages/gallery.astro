---

<BaseLayout
  title="Project Gallery"
  description={`Browse recent plumbing, remodeling, excavation and concrete projects by Nesbitt's Plumbing across Asheville & Hendersonville, NC. Call ${site.phone} for your project.`}
>
  <Hero
    title="Our Work Speaks for Itself"
    subtitle="From water heater installs to full kitchen remodels and commercial site work — take a look at some of our recent projects across Western North Carolina."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5">
      {
        items.map((item) => (
          <figure class="break-inside-avoid overflow-hidden rounded-2xl border border-charcoal-100 bg-white shadow-sm">
            <a href={item.src} target="_blank" rel="noopener">
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full transition-transform duration-300 hover:scale-[1.02]"
              />
            </a>
            {item.caption && (
              <figcaption class="px-5 py-3.5 text-sm font-medium text-charcoal-700">
                {item.caption}
              </figcaption>
            )}
          </figure>
        ))
      }
    </div>
  </section>

  <CtaBand heading="Want Results Like These?" />
</BaseLayout>
