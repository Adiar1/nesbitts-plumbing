---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBand from '../components/CtaBand.astro';
import WaterDrop from '../components/WaterDrop.astro';
import { site } from '../data/site';

const valueDetails = [
  {
    name: 'Attitude',
    text: 'We show up ready to help, treat your home with respect, and stand behind our work: every job, every customer.',
  },
  {
    name: 'Courage',
    text: "No job is too tough. From basements full of water to full-scale remodels, we tackle the problems others walk away from.",
  },
  {
    name: 'Training',
    text: 'Our plumbers and contractors are fully licensed, insured, and continually trained on the latest tools and techniques.',
  },
];
---

<BaseLayout
  title="About Us"
  description={`Nesbitt's Plumbing (NPSCorp), family owned and operated, serving Asheville & Hendersonville, NC since ${site.founded}. ${site.yearsInBusiness} years of licensed, insured plumbing and remodeling.`}
>
  <Hero
    showEstBadge
    title="Family Owned. Locally Trusted."
    subtitle={`${site.tagline}. Nesbitt's Plumbing has proudly served ${site.serviceArea} since ${site.founded}.`}
    image="/images/hero-bathroom.jpg"
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-2">
      <div class="space-y-5 text-base leading-relaxed text-charcoal-700 sm:text-lg">
        <p class="text-sm font-bold uppercase tracking-widest text-drop-600">Our Story</p>
        <h2 class="!mt-2 text-3xl font-extrabold tracking-tight text-charcoal-900 sm:text-4xl">
          {site.yearsInBusiness} Years of Reliable Plumbing
        </h2>
        <p>
          Since {site.founded}, homeowners and businesses across Asheville, Hendersonville, and
          Western North Carolina have trusted Nesbitt's Plumbing ({site.legalName}) with their
          plumbing installation, repair, and remodeling. We started as a small family operation and
          grew into a full-service plumbing and contracting company, but the promise behind the
          name hasn't changed: show up on time, do honest work, and get it right the first time.
        </p>
        <p>
          We're still family owned and operated, fully licensed and insured, and we treat every
          house like it's our own. A clogged drain, an aging water heater, or the kitchen you've
          been picturing for years, we can handle all of it under one roof.
        </p>
        <p>
          We serve residential and commercial customers within about an hour of Asheville or
          Hendersonville, NC. Call us for a free estimate at
          <a href={site.phoneHref} class="font-semibold text-drop-600 hover:underline">{site.phone}</a>.
        </p>
      </div>

      <div class="flex flex-col justify-center rounded-2xl bg-navy-950 p-8 text-white sm:p-10">
        <WaterDrop class="h-10 w-10" />
        <p class="mt-5 text-2xl font-extrabold leading-snug sm:text-3xl">
          "{site.tagline}"
        </p>
        <p class="mt-4 text-sm font-bold uppercase tracking-widest text-drop-300">
          {site.legalName} &bull; {site.est}
        </p>
        <div class="mt-8 grid grid-cols-3 gap-4 border-t border-navy-800 pt-8 text-center">
          <div>
            <p class="text-3xl font-extrabold text-drop-400">{site.yearsInBusiness}</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-charcoal-200">Years in Business</p>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-drop-400">100%</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-charcoal-200">Licensed &amp; Insured</p>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-drop-400">$25</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-charcoal-200">Off for New Customers</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-charcoal-50">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-widest text-drop-600">What Drives Us</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-charcoal-900 sm:text-4xl">
          Attitude, Courage, Training
        </h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          valueDetails.map((v) => (
            <div class="rounded-2xl border border-charcoal-100 bg-white p-7 shadow-sm">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-drop-100 text-xl font-extrabold text-drop-600">
                {v.name.charAt(0)}
              </span>
              <h3 class="mt-4 text-xl font-bold text-navy-900">{v.name}</h3>
              <p class="mt-3 leading-relaxed text-charcoal-600">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    heading="Talk to a Plumber Who Knows the Area"
    text={`Call ${site.phone} for a free estimate from a local team that answers the phone and stands behind every job.`}
  />
</BaseLayout>
