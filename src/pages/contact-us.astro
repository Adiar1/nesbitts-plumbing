---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Contact Us"
  description={`Contact Nesbitt's Plumbing in Arden, NC. Call ${site.phone} or send us a message for a free estimate on plumbing and remodeling in Asheville & Hendersonville, NC.`}
>
  <Hero
    title="Let's Get Your Water Back In-Line"
    subtitle="Request a free estimate, ask a question, or schedule service. We look forward to hearing from you!"
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-[24rem_1fr]">
      <!-- Contact info -->
      <div class="space-y-8">
        <div class="rounded-2xl bg-navy-950 p-8 text-white">
          <h2 class="text-xl font-bold">Nesbitt's Plumbing</h2>
          <p class="mt-1 text-sm font-semibold tracking-wider text-drop-300">
            {site.legalName} &bull; {site.est}
          </p>
          <address class="mt-5 space-y-4 not-italic text-charcoal-200">
            <p>
              <a href={site.address.mapsHref} target="_blank" rel="noopener noreferrer" class="hover:text-drop-300">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </a>
            </p>
            <p>
              <span class="block text-xs font-bold uppercase tracking-wider text-charcoal-500">Phone</span>
              <a href={site.phoneHref} class="text-lg font-bold text-white hover:text-drop-300">{site.phone}</a>
            </p>
            <p>
              <span class="block text-xs font-bold uppercase tracking-wider text-charcoal-500">Email</span>
              <a href={site.emailHref} class="break-all hover:text-drop-300">{site.email}</a>
            </p>
          </address>
          <a
            href={site.address.mapsHref}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-block rounded-lg bg-drop-500 px-5 py-2.5 text-sm font-bold text-navy-950 transition-colors hover:bg-drop-400"
          >
            Get Directions
          </a>
        </div>

        <div class="rounded-2xl border border-charcoal-100 bg-charcoal-50 p-8">
          <h2 class="text-lg font-bold text-navy-900">Business Hours</h2>
          <ul class="mt-4 space-y-2 text-sm">
            {
              site.hours.map((h) => (
                <li class="flex justify-between gap-4 border-b border-charcoal-100 pb-2 last:border-0">
                  <span class="font-semibold text-charcoal-800">{h.day}</span>
                  <span class="text-charcoal-600">{h.time}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Contact form -->
      <div>
        <h2 class="text-2xl font-bold text-charcoal-900 sm:text-3xl">Send Us a Message</h2>
        <p class="mt-3 leading-relaxed text-charcoal-600">
          Thank you for visiting our website. Please fill out the following form to send us a
          message, you may use it to request more information about our products and services,
          request a free estimate, or provide feedback. We look forward to hearing from you!
        </p>

        {/*
          NOTE: This form needs a submission backend. If deploying to Netlify, the
          `data-netlify` attribute below makes it work out of the box. Otherwise, point the
          `action` at your form provider (Formspree, Basin, etc.).
        */}
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="mt-8 grid gap-5 sm:grid-cols-2"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div>
            <label for="name" class="block text-sm font-semibold text-charcoal-800">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="mt-1.5 w-full rounded-lg border border-charcoal-200 px-4 py-2.5 focus:border-drop-500 focus:outline-none focus:ring-2 focus:ring-drop-300"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-charcoal-800">Phone *</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              class="mt-1.5 w-full rounded-lg border border-charcoal-200 px-4 py-2.5 focus:border-drop-500 focus:outline-none focus:ring-2 focus:ring-drop-300"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="email" class="block text-sm font-semibold text-charcoal-800">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="mt-1.5 w-full rounded-lg border border-charcoal-200 px-4 py-2.5 focus:border-drop-500 focus:outline-none focus:ring-2 focus:ring-drop-300"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="service" class="block text-sm font-semibold text-charcoal-800">What do you need help with?</label>
            <select
              id="service"
              name="service"
              class="mt-1.5 w-full rounded-lg border border-charcoal-200 bg-white px-4 py-2.5 focus:border-drop-500 focus:outline-none focus:ring-2 focus:ring-drop-300"
            >
              <option>General Plumbing Repair</option>
              <option>Hot Water Heater</option>
              <option>Leak Detection</option>
              <option>Pipe Replacement</option>
              <option>Sewer & Water Lines</option>
              <option>Video Inspection</option>
              <option>Kitchen or Bathroom Remodel</option>
              <option>New Construction Plumbing</option>
              <option>Concrete Removal</option>
              <option>Other / Write a Review</option>
            </select>
          </div>
          <div class="sm:col-span-2">
            <label for="message" class="block text-sm font-semibold text-charcoal-800">Message *</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1.5 w-full rounded-lg border border-charcoal-200 px-4 py-2.5 focus:border-drop-500 focus:outline-none focus:ring-2 focus:ring-drop-300"
            ></textarea>
          </div>
          <div class="sm:col-span-2">
            <button
              type="submit"
              class="w-full rounded-lg bg-navy-900 px-8 py-3.5 font-bold text-white transition-colors hover:bg-navy-800 sm:w-auto"
            >
              Submit
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
