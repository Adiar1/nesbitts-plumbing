---
import { nav, site } from '../data/site';
import SocialLinks from './SocialLinks.astro';
import WaterDrop from './WaterDrop.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-40 shadow-md">
  <!-- Top utility bar -->
  <div class="bg-navy-950 text-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-1.5 text-sm sm:px-6">
      <p class="hidden items-center gap-2 text-charcoal-200 md:flex">
        <WaterDrop class="h-3.5 w-3.5 text-drop-400" />
        <span>{site.tagline}</span>
        <span class="mx-1 text-navy-700">|</span>
        <span class="font-semibold tracking-wide text-drop-300">{site.est}</span>
      </p>
      <div class="flex w-full items-center justify-between gap-4 md:w-auto md:justify-end">
        <a
          href={site.phoneHref}
          class="flex items-center gap-1.5 font-semibold text-white transition-colors hover:text-drop-300"
        >
          <svg class="h-4 w-4 text-drop-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8a15.6 15.6 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.4.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1l-2.3 2.2Z" />
          </svg>
          {site.phone}
        </a>
        <SocialLinks class="flex items-center gap-3 text-charcoal-200" iconClass="h-4 w-4" />
      </div>
    </div>
  </div>

  <!-- Main navigation -->
  <div class="bg-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
      <a href="/" class="flex shrink-0 items-center gap-2" aria-label={`${site.name} — Home`}>
        <img src={site.logo} alt={`${site.name} logo`} class="h-11 w-auto sm:h-12" />
        <span class="sr-only">{site.name}</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden items-center gap-0.5 xl:flex" aria-label="Main navigation">
        {
          nav.map((item) =>
            item.children ? (
              <div class="group relative">
                <a
                  href={item.href}
                  class:list={[
                    'flex items-center gap-1 whitespace-nowrap rounded-md px-2.5 py-2 text-sm font-semibold transition-colors',
                    isActive(item.href)
                      ? 'text-navy-800'
                      : 'text-charcoal-700 hover:text-navy-800',
                  ]}
                >
                  {item.label}
                  <svg class="h-4 w-4 text-charcoal-500 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 15.5 5.5 9l1.4-1.4L12 12.7l5.1-5.1L18.5 9 12 15.5Z" />
                  </svg>
                </a>
                <div class="invisible absolute left-0 top-full z-50 w-72 pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                  <ul class="overflow-hidden rounded-lg border border-charcoal-100 bg-white py-2 shadow-xl">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class="flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-charcoal-700 transition-colors hover:bg-drop-100 hover:text-navy-800"
                        >
                          <WaterDrop class="h-3.5 w-3.5 shrink-0 text-drop-400" />
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'whitespace-nowrap rounded-md px-2.5 py-2 text-sm font-semibold transition-colors',
                  isActive(item.href)
                    ? 'text-navy-800'
                    : 'text-charcoal-700 hover:text-navy-800',
                ]}
              >
                {item.label}
              </a>
            )
          )
        }
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="/contact-us"
          class="hidden rounded-lg bg-drop-500 px-5 py-2.5 text-sm font-bold text-navy-950 shadow-sm transition-colors hover:bg-drop-400 xl:inline-block"
        >
          Request Service
        </a>
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-button"
          type="button"
          class="rounded-md p-2 text-charcoal-800 hover:bg-charcoal-100 xl:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open main menu"
        >
          <svg id="icon-open" class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3 6h18v2H3V6Zm0 5h18v2H3v-2Zm0 5h18v2H3v-2Z" />
          </svg>
          <svg id="icon-close" class="hidden h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="m6.4 5 5.6 5.6L17.6 5 19 6.4 13.4 12l5.6 5.6-1.4 1.4-5.6-5.6L5.4 19 4 17.6 9.6 12 4 6.4 5.4 5h1Z" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="hidden border-t border-charcoal-100 bg-white xl:hidden" aria-label="Mobile navigation">
      <ul class="space-y-1 px-4 py-4">
        {
          nav.map((item) =>
            item.children ? (
              <li>
                <details class="group/details">
                  <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-2.5 font-semibold text-charcoal-800 hover:bg-charcoal-50 [&::-webkit-details-marker]:hidden">
                    {item.label}
                    <svg class="h-5 w-5 text-charcoal-500 transition-transform group-open/details:rotate-180" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 15.5 5.5 9l1.4-1.4L12 12.7l5.1-5.1L18.5 9 12 15.5Z" />
                    </svg>
                  </summary>
                  <ul class="mt-1 space-y-1 border-l-2 border-drop-300 pl-4">
                    <li>
                      <a href={item.href} class="block rounded-md px-3 py-2 text-sm font-semibold text-navy-800 hover:bg-drop-100">
                        {item.label} — Overview
                      </a>
                    </li>
                    {item.children.map((child) => (
                      <li>
                        <a href={child.href} class="block rounded-md px-3 py-2 text-sm font-medium text-charcoal-700 hover:bg-drop-100 hover:text-navy-800">
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a href={item.href} class="block rounded-md px-3 py-2.5 font-semibold text-charcoal-800 hover:bg-charcoal-50">
                  {item.label}
                </a>
              </li>
            )
          )
        }
        <li class="pt-2">
          <a
            href="/contact-us"
            class="block rounded-lg bg-drop-500 px-5 py-3 text-center font-bold text-navy-950 hover:bg-drop-400"
          >
            Request Service
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  button?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    button.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
