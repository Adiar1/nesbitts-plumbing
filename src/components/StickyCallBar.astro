---
import { site } from '../data/site';
---

<!-- Sticky mobile call-to-action bar -->
<div class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-2 border-t border-navy-800 shadow-[0_-4px_12px_rgba(0,0,0,0.25)] xl:hidden">
  <a
    href={site.phoneHref}
    class="flex items-center justify-center gap-2 bg-navy-900 px-4 py-3.5 text-sm font-bold text-white transition-colors active:bg-navy-800"
  >
    <svg class="h-5 w-5 text-drop-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M6.6 10.8a15.6 15.6 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.4.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1l-2.3 2.2Z" />
    </svg>
    Call Now
  </a>
  <a
    href="/contact-us"
    class="flex items-center justify-center gap-2 bg-drop-500 px-4 py-3.5 text-sm font-bold text-navy-950 transition-colors active:bg-drop-400"
  >
    Request Service
  </a>
</div>

<!-- Spacer so page content isn't hidden behind the fixed bar on mobile -->
<div class="h-[52px] xl:hidden" aria-hidden="true"></div>
