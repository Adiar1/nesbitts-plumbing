---
import dropSrc from '../assets/water-drop.png';

interface Props {
  class?: string;
}
const { class: className = 'h-5 w-5' } = Astro.props;
---

<img
  src={dropSrc.src}
  width={dropSrc.width}
  height={dropSrc.height}
  alt=""
  aria-hidden="true"
  loading="lazy"
  decoding="async"
  class:list={['object-contain', className]}
/>
