---
import { site } from '../data/site';
import WaterDrop from './WaterDrop.astro';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = `Need a Plumber in Asheville or Hendersonville, NC?`,
  text = `Call ${site.phone} today or request a free estimate online.`,
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-navy-900">
  <WaterDrop class="absolute -right-8 -top-10 h-56 w-56 rotate-12 text-navy-800/60" />
  <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-6 px-4 py-14 sm:px-6 lg:flex-row lg:items-center">
    <div>
      <h2 class="text-2xl font-extrabold tracking-tight text-white sm:text-3xl">{heading}</h2>
      <p class="mt-2 text-lg text-charcoal-100">{text}</p>
    </div>
    <div class="flex shrink-0 flex-wrap gap-4">
      <a
        href={site.phoneHref}
        class="rounded-lg bg-drop-500 px-7 py-3.5 font-bold text-navy-950 shadow-lg transition-colors hover:bg-drop-400"
      >
        Call {site.phone}
      </a>
      <a
        href="/contact-us"
        class="rounded-lg border-2 border-white/70 px-7 py-3 font-bold text-white transition-colors hover:border-drop-300 hover:text-drop-300"
      >
        Contact Us
      </a>
    </div>
  </div>
</section>
