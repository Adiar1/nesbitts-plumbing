---
import { site } from '../data/site';

interface Props {
  class?: string;
  iconClass?: string;
}
const { class: className = 'flex items-center gap-3', iconClass = 'h-5 w-5' } = Astro.props;
---

<div class={className}>
  <a
    href={site.social.facebook}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Nesbitt's Plumbing on Facebook"
    class="transition-colors hover:text-drop-400"
  >
    <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2a10 10 0 0 0-1.8 19.8v-7.6H7.7v-2.9h2.5V9.2c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6v1.8h2.8l-.4 2.9h-2.4v7.6A10 10 0 0 0 12 2Z" />
    </svg>
  </a>
  <a
    href={site.social.instagram}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Nesbitt's Plumbing on Instagram"
    class="transition-colors hover:text-drop-400"
  >
    <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2.2c2.7 0 3 0 4 .1 1 0 1.7.2 2.3.4.6.3 1.1.6 1.6 1.1.5.5.9 1 1.1 1.6.2.6.4 1.3.4 2.3.1 1 .1 1.4.1 4.1s0 3-.1 4c0 1-.2 1.7-.4 2.3a4.7 4.7 0 0 1-1.1 1.7c-.5.5-1 .8-1.6 1-.6.3-1.3.5-2.3.5-1 .1-1.3.1-4 .1s-3.1 0-4.1-.1c-1 0-1.7-.2-2.3-.4a4.7 4.7 0 0 1-1.6-1.1c-.5-.5-.9-1-1.1-1.7-.2-.5-.4-1.3-.4-2.3-.1-1-.1-1.3-.1-4s0-3.1.1-4.1c0-1 .2-1.7.4-2.3.3-.6.6-1.1 1.1-1.6.5-.5 1-.9 1.6-1.1.6-.2 1.3-.4 2.3-.4 1-.1 1.4-.1 4.1-.1Zm0 1.8c-2.7 0-3 0-4 .1-1 0-1.5.2-1.8.3-.5.2-.8.4-1.1.7-.4.4-.6.7-.8 1.1-.1.4-.3.9-.3 1.9-.1 1-.1 1.3-.1 4s0 3 .1 4c0 .9.2 1.4.3 1.8.2.4.4.7.8 1 .3.4.6.6 1 .8.4.1.9.3 1.9.3 1 .1 1.3.1 4 .1s3 0 4-.1c1 0 1.5-.2 1.8-.3.5-.2.8-.4 1.1-.7.3-.3.5-.6.7-1.1.1-.4.3-.9.3-1.9.1-1 .1-1.3.1-4s0-3-.1-4c0-.9-.2-1.4-.3-1.8-.2-.4-.4-.7-.7-1a2.9 2.9 0 0 0-1.1-.8c-.3-.1-.9-.3-1.9-.3-1-.1-1.2-.1-4-.1ZM12 7a5 5 0 1 1 0 10.1A5 5 0 0 1 12 7Zm0 8.3a3.3 3.3 0 1 0 0-6.5 3.3 3.3 0 0 0 0 6.5Zm6.4-8.5a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0Z" />
    </svg>
  </a>
  <a
    href={site.social.tiktok}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Nesbitt's Plumbing on TikTok"
    class="transition-colors hover:text-drop-400"
  >
    <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M16.6 2h-3.3v13.7a2.9 2.9 0 1 1-2.9-2.9c.3 0 .6 0 .9.1V9.5a6.3 6.3 0 0 0-.9-.1 6.2 6.2 0 1 0 6.2 6.3V8.6a7.7 7.7 0 0 0 4.5 1.4V6.7A4.5 4.5 0 0 1 16.6 2Z" />
    </svg>
  </a>
</div>
